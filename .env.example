# Budget Manager — environment contract (names only, NO values).
# Copy to .env and fill in per environment. .env is gitignored.
#
# For local development, `supabase start` prints a local API URL and anon key you
# can paste here. These are consumed by the frontend (Phase 2+); Phase 1 (schema &
# integrity) runs entirely against the local Supabase stack and needs none of them.

# Public Supabase project URL (safe to ship to the browser).
VITE_SUPABASE_URL=

# Public anon key (safe to ship; RLS is the guard).
VITE_SUPABASE_ANON_KEY=

# NOTE: the service_role key must NEVER live in this file, the client bundle, or the
# repo. It belongs only in server-side / CI secret storage.
