{
  "name": "budget-app",
  "version": "0.1.0",
  "private": true,
  "description": "Budget Manager — installable, online-only PWA (Supabase backend). Phase 1: schema & integrity core.",
  "type": "module",
  "scripts": {
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "gen:types": "supabase gen types typescript --local > src/types/database.types.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run db:test"
  },
  "devDependencies": {
    "supabase": "^2.109.1",
    "typescript": "^5.6.0"
  }
}
